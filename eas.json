{
  "cli": {
    "version": ">= 18.6.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development-consumer": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "consumer"
      }
    },
    "development-operator": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "operator"
      }
    },
    "development-consumer-simulator": {
      "extends": "development-consumer",
      "ios": {
        "simulator": true
      }
    },
    "development-operator-simulator": {
      "extends": "development-operator",
      "ios": {
        "simulator": true
      }
    },
    "preview-consumer": {
      "distribution": "internal",
      "channel": "preview-consumer",
      "env": {
        "APP_VARIANT": "consumer"
      }
    },
    "preview-operator": {
      "distribution": "internal",
      "channel": "preview-operator",
      "env": {
        "APP_VARIANT": "operator"
      }
    },
    "production-consumer": {
      "autoIncrement": true,
      "channel": "production-consumer",
      "env": {
        "APP_VARIANT": "consumer"
      }
    },
    "production-operator": {
      "autoIncrement": true,
      "channel": "production-operator",
      "env": {
        "APP_VARIANT": "operator"
      }
    }
  },
  "submit": {
    "production-consumer": {},
    "production-operator": {}
  }
}
