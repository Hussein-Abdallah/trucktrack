# TruckTrack environment variables
# ---------------------------------
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.
#
# Every value prefixed EXPO_PUBLIC_ is baked into the JS bundle and
# readable by anyone who inspects the app binary. Only put keys that
# are designed to be public (sb_publishable_* / anon) there.
# Any value without the EXPO_PUBLIC_ prefix is server-side only
# (Edge Functions, CI scripts) and must never be added to the bundle.

# Supabase -----------------------------------------------------------
# Get all four values from: Supabase Dashboard → Project Settings → API.
#
# We carry BOTH the new (sb_publishable_* / sb_secret_*) and legacy
# (anon JWT / service_role JWT) keys on disk. The app code picks which
# one to use when the Supabase client is wired up in a later ticket.
# Rationale:
#   - New format: recommended by Supabase, proper rotation support,
#     no 10-year expiry. Use this in the React Native client.
#   - Legacy format: Supabase Edge Functions auto-inject
#     SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY
#     with these legacy JWT values — saves per-function secrets
#     configuration. Keep them available for Edge Functions until we
#     decide otherwise.

# Project URL (safe, public) — e.g. https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# --- New key format (preferred for the app client) ---

# Publishable key (safe, public) — starts with sb_publishable_...
# Security model: depends on RLS being enabled with policies that
# correctly restrict each row. Never skip RLS for tables queried with
# this key.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Secret key (SECRET — server-side only) — starts with sb_secret_...
# Used by Edge Functions / CI when explicitly opted-in via
# `supabase secrets set SUPABASE_SECRET_KEY=...`. Bypasses RLS.
# Never use this key in the React Native app.
# Never commit this value. If it leaks, rotate immediately via
# Supabase Dashboard → Project Settings → API.
SUPABASE_SECRET_KEY=sb_secret_your_key_here

# --- Legacy key format (kept for Edge Function auto-injection) ---

# Anon JWT (safe, public) — starts with eyJhbGc...
# Rotating the JWT secret regenerates both anon and service_role
# together. If either leaks, rotate both.
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt-here

# Service role JWT (SECRET — server-side only) — starts with eyJhbGc...
# Auto-injected into Edge Functions by the Supabase runtime.
# Same rotation rule as above.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-here

# Mapbox -------------------------------------------------------------
# Get both from: https://account.mapbox.com/access-tokens
#
# Two distinct tokens — don't swap them. The MapView wrapper fails loud
# at import if EXPO_PUBLIC_MAPBOX_TOKEN starts with sk., to prevent the
# secret token leaking into the JS bundle.

# Public access token (safe, public) — starts with pk.eyJ...
# Bundled into the app, used at render time by @rnmapbox/maps.
# Free tier covers 50,000 map loads/month.
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# Secret download token (SECRET — build-time only) — starts with sk.eyJ...
# Scope: Downloads:Read. Read by @rnmapbox/maps' config plugin at native
# build time so it can pull the Mapbox SDK from their private artifact
# registry. Consumed by EAS Build (or local prebuild) — never bundled
# into the JS. The env var name is fixed by the library; don't rename.
# Mirror to EAS via:
#   eas secret:create --scope project --name RNMAPBOX_MAPS_DOWNLOAD_TOKEN --value sk.eyJ...
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=sk.your-mapbox-downloads-token
