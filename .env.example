# TruckTrack environment variables
# ---------------------------------
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.
#
# Every value prefixed EXPO_PUBLIC_ is baked into the JS bundle and
# readable by anyone who inspects the app binary. Only put keys that
# are designed to be public (sb_publishable_* / anon) there.
# Any value without the EXPO_PUBLIC_ prefix is server-side only
# (Edge Functions, CI scripts) and must never be added to the bundle.

# Supabase -----------------------------------------------------------
# Get from: Supabase Dashboard → Project Settings → API.
# We use the new sb_publishable_* / sb_secret_* key format
# (recommended by Supabase over the legacy anon / service_role JWTs;
# proper rotation support, no multi-year expiry).

# Project URL (safe, public) — e.g. https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key (safe, public) — starts with sb_publishable_...
# Security model: depends on RLS being enabled with policies that
# correctly restrict each row. Never skip RLS for tables queried with
# this key.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Secret key (SECRET — server-side only) — starts with sb_secret_...
# Used by Edge Functions and CI. Bypasses RLS. Never use this key in
# the React Native app.
# Never commit this value. If it leaks, rotate immediately via
# Supabase Dashboard → Project Settings → API.
SUPABASE_SECRET_KEY=sb_secret_your_key_here
