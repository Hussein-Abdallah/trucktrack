{
  "name": "trucktrack",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "cross-env APP_VARIANT=consumer expo start",
    "start:consumer": "cross-env APP_VARIANT=consumer expo start",
    "start:operator": "cross-env APP_VARIANT=operator expo start",
    "android": "cross-env APP_VARIANT=consumer expo start --android",
    "android:consumer": "cross-env APP_VARIANT=consumer expo start --android",
    "android:operator": "cross-env APP_VARIANT=operator expo start --android",
    "ios": "cross-env APP_VARIANT=consumer expo start --ios",
    "ios:consumer": "cross-env APP_VARIANT=consumer expo start --ios",
    "ios:operator": "cross-env APP_VARIANT=operator expo start --ios",
    "web": "cross-env APP_VARIANT=consumer expo start --web",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:reset": "npx supabase db reset",
    "db:migrate": "npx supabase db push",
    "db:migration:new": "npx supabase migration new"
  },
